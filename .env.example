# =============================================================================
# .env.example — Variáveis de ambiente para Docker
# NUNCA commite o arquivo .env real — apenas este .example
# Copie para .env e preencha com valores reais:
#   cp .env.example .env
# =============================================================================

# ── MySQL ────────────────────────────────────────────────────────────────────
# ⚠️ ADAPTE: use senhas fortes em produção (min 16 caracteres, aleatórias)
MYSQL_ROOT_PASSWORD=troque_por_senha_forte_root
MYSQL_DATABASE=agendaflow
MYSQL_USER=agendauser
MYSQL_PASSWORD=troque_por_senha_forte_user

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3000

# ⚠️ ADAPTE: gere valores aleatórios com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere_um_segredo_aleatorio_longo_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=gere_outro_segredo_aleatorio_aqui
JWT_REFRESH_EXPIRES_IN=30d

# ── Front-end ────────────────────────────────────────────────────────────────
# ⚠️ ADAPTE: em produção, substitua pelo domínio real da sua API
VITE_API_URL=http://localhost:3000
