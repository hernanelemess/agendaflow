# =============================================================================
# .dockerignore — agendaflow-api
# Funciona como .gitignore mas para o Docker build context.
# Arquivos listados aqui NÃO são enviados para o daemon do Docker.
# Isso reduz o tamanho do contexto e evita vazar credenciais na imagem.
# =============================================================================

# Dependências — serão instaladas dentro do container
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ⚠️ SEGURANÇA: nunca enviar arquivos de ambiente para a imagem
.env
.env.*
!.env.example    # exceção: o exemplo pode ir (não tem credenciais reais)

# Controle de versão
.git/
.gitignore

# Arquivos Docker (não precisam estar dentro da imagem)
Dockerfile*
docker-compose*
.dockerignore

# Arquivos de desenvolvimento e testes
*.test.js
*.spec.js
__tests__/
coverage/
.nyc_output/

# Logs
logs/
*.log

# Arquivos do editor
.vscode/
.idea/
*.swp
*.swo

# Sistema operacional
.DS_Store
Thumbs.db

# Documentação (não é necessária em runtime)
README.md
ROUTES.md
docs/

# Scripts de seed — não devem rodar em produção automaticamente
database/seeders/
